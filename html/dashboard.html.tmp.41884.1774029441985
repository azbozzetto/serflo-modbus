    <script>
        // ── Estado ──────────────────────────────────────────────────────────
        let chart = null;
        let currentHours = 1;
        let currentOffset = 0;   // horas hacia atrás desde ahora (modo live)
        let currentDayMode = false;
        let currentViewDate = '';        // 'YYYY-MM-DD' activo en modo día
        let lastData = null;
        let refreshTimer = null;
        let isZoomed = false;
        let chartExpanded = false;
        let appMode = 'live';            // 'live' | 'partida' (producción)
        let currentPartidaId = null;
        let allPartidas = [];
        let recentReadings = [];         // [{hora, vl, temp, stats}] newest first
        const MAX_LOG = 3;
        const REFRESH_INTERVAL = 10000;
        let lastAnnotations = {};        // todas las anotaciones sin filtro
        let showEventos  = true;
        let showMuestras = true;
        let dragAnn      = null;   // key de la anotación siendo arrastrada
        let dragStartY   = 0;
        let dragStartAdj = 0;

        // ── Helpers ────────────────────────────────────────────────────────
        function computeRollingStats(data) {
            // Para cada índice i retorna stats acumuladas desde 0 hasta i (inclusive).
            // O(n) — un solo pase. stats[i] = {vl:{min,max,avg,sum,count}, temp:{...}}
            const n    = data.timestamps ? data.timestamps.length : 0;
            const vls  = data.vl          || [];
            const tmps = data.temperature || [];
            let vlMin = Infinity, vlMax = -Infinity, vlSum = 0, vlN = 0;
            let tMin  = Infinity, tMax  = -Infinity, tSum  = 0, tN  = 0;
            const out = [];
            for (let i = 0; i < n; i++) {
                const v = vls[i], t = tmps[i];
                if (v != null) { if (v < vlMin) vlMin = v; if (v > vlMax) vlMax = v; vlSum += v; vlN++; }
                if (t != null) { if (t < tMin)  tMin  = t; if (t > tMax)  tMax  = t; tSum  += t; tN++;  }
                out.push({
                    vl:   vlN ? { min: vlMin, max: vlMax, avg: vlSum / vlN, sum: vlSum, count: vlN } : null,
                    temp: tN  ? { min: tMin,  max: tMax,  avg: tSum  / tN,  sum: tSum,  count: tN  } : null
                });
            }
            return out;
        }

        function extendStats(prev, vl, temp) {
            // Extiende un objeto de stats acumuladas con un nuevo valor.
            const ext = (s, v) => {
                if (v == null) return s;
                if (!s) return { min: v, max: v, avg: v, sum: v, count: 1 };
                const count = s.count + 1, sum = s.sum + v;
                return { min: Math.min(s.min, v), max: Math.max(s.max, v), avg: sum / count, sum, count };
            };
            return {
                vl:   ext(prev ? prev.vl   : null, vl),
                temp: ext(prev ? prev.temp : null, temp)
            };
        }

        function fmtNum(v, decimals = 1) {
            if (v == null || v === '') return '—';
            const n = parseFloat(v);
            if (isNaN(n)) return '—';
            return n.toLocaleString('en-US', {
                minimumFractionDigits: decimals,
                maximumFractionDigits: decimals
            });
        }
        function nowTimeStr() {
            return new Date().toTimeString().substring(0, 5);
        }
        function todayStr() {
            // Fecha local en formato YYYY-MM-DD
            const d = new Date();
            return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`;
        }
        function addDays(dateStr, n) {
            // Suma n días a 'YYYY-MM-DD' sin problemas de zona horaria
            const [y, m, d] = dateStr.split('-').map(Number);
            const dt = new Date(y, m - 1, d + n);
            return `${dt.getFullYear()}-${String(dt.getMonth()+1).padStart(2,'0')}-${String(dt.getDate()).padStart(2,'0')}`;
        }
        function timeToMinutes(s) {
            const p = s.substring(0, 5).split(':');
            return parseInt(p[0]) * 60 + parseInt(p[1]);
        }
        function labelTimePart(lbl) {
            // Soporta tres formatos de label del gráfico:
            //   "HH:MM"        → hhmmss/hhmm mode ≤1h
            //   "HH:MM:SS"     → hhmmss mode
            //   "MM-DD HH:MM"  → day/partida mode  (lbl[2] === '-')
            if (lbl && lbl.length >= 11 && lbl[2] === '-') return lbl.substring(6, 11); // "HH:MM"
            return lbl ? lbl.substring(0, 5) : '';
        }

        function isTimeInRange(labels, timeStr) {
            // Devuelve true si timeStr ('HH:MM') cae dentro del rango visible del gráfico.
            if (!labels || labels.length < 2) return false;
            const target = timeToMinutes(timeStr.substring(0, 5));
            const first  = timeToMinutes(labelTimePart(labels[0]));
            const last   = timeToMinutes(labelTimePart(labels[labels.length - 1]));
            if (last >= first) {
                return target >= first && target <= last;
            } else {
                // Rango que cruza la medianoche
                return target >= first || target <= last;
            }
        }

        function applyAnnotationVisibility() {
            if (!chart) return;
            const filtered = {};
            Object.keys(lastAnnotations).forEach(key => {
                if (key.startsWith('evt_') && !showEventos)  return;
                if (key.startsWith('mst_') && !showMuestras) return;
                filtered[key] = lastAnnotations[key];
            });
            chart.options.plugins.annotation.annotations = filtered;
            chart.update('none');
        }

        function getViewPartidaId(data) {
            // Determina qué partida corresponde a los datos visualmente mostrados.
            // Modo partida: usa siempre la partida seleccionada.
            // Modo live/day: busca en allPartidas la que coincide con la fecha
            //   del timestamp central del dataset cargado.
            if (appMode === 'partida') return currentPartidaId;
            if (!data || !data.timestamps || !data.timestamps.length) return null;
            const mid = data.timestamps[Math.floor(data.timestamps.length / 2)];
            const viewDate = mid.substring(0, 10);   // 'YYYY-MM-DD'
            const p = allPartidas.find(x => x.fecha === viewDate);
            return p ? p.id : null;
        }

        function findLabelIndex(labels, timeStr) {
            if (!labels || !labels.length) return 0;
            const target = timeToMinutes(timeStr.substring(0, 5));
            let best = 0, bestDiff = Infinity;
            labels.forEach((lbl, i) => {
                const d = Math.abs(timeToMinutes(labelTimePart(lbl)) - target);
                if (d < bestDiff) { bestDiff = d; best = i; }
            });
            return best;
        }

        // ── Chart ──────────────────────────────────────────────────────────
        function initChart() {
            const ctx = document.getElementById('chart').getContext('2d');
            chart = new Chart(ctx, {
                type: 'line',
                data: {
                    labels: [],
                    datasets: [
                        {
                            label: 'Viscosidad VL (cP)',
                            data: [],
                            borderColor: '#4fc3f7',
                            backgroundColor: 'rgba(79,195,247,0.08)',
                            fill: true,
                            yAxisID: 'y-vl',
                            pointRadius: 0,
                            borderWidth: 2,
                            tension: 0.3
                        },
                        {
                            label: 'Temperatura (\u00b0C)',
                            data: [],
                            borderColor: '#ff8a65',
                            fill: false,
                            yAxisID: 'y-temp',
                            pointRadius: 0,
                            borderWidth: 2,
                            tension: 0.3
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    layout: { padding: { bottom: 8 } },
                    interaction: { mode: 'index', intersect: false },
                    plugins: {
                        legend: {
                            labels: {
                                color: '#aaa',
                                font: { size: 14 },
                                usePointStyle: true,
                                pointStyleWidth: 22,
                                generateLabels: function(chart) {
                                    const items = Chart.defaults.plugins.legend.labels.generateLabels(chart);
                                    items.forEach((item, i) => {
                                        if (i === 0) {
                                            // Viscosidad → recuadro de área
                                            item.pointStyle = 'rect';
                                            item.fillStyle = 'rgba(79,195,247,0.35)';
                                            item.strokeStyle = '#4fc3f7';
                                            item.lineWidth = 1;
                                        } else {
                                            // Temperatura → línea
                                            item.pointStyle = 'line';
                                            item.strokeStyle = '#ff8a65';
                                            item.lineWidth = 2;
                                        }
                                    });
                                    return items;
                                }
                            }
                        },
                        tooltip: {
                            backgroundColor: '#1a2733',
                            borderColor: '#2a3a4a',
                            borderWidth: 1,
                            titleColor: '#fff',
                            bodyColor: '#ccc',
                            callbacks: { title: items => items[0].label }
                        },
                        annotation: { annotations: {} },
                        zoom: {
                            zoom: {
                                drag: {
                                    enabled: true,
                                    backgroundColor: 'rgba(79,195,247,0.08)',
                                    borderColor: 'rgba(79,195,247,0.5)',
                                    borderWidth: 1
                                },
                                wheel: {
                                    enabled: true,
                                    speed: 0.08
                                },
                                mode: 'x',
                                onZoomComplete: ({ chart }) => {
                                    isZoomed = true;
                                    document.getElementById('btn-reset-zoom').classList.add('zoomed');
                                    document.getElementById('refresh-info').textContent = 'Zoom activo \u2014 refresco pausado';
                                    updateMedicionesForZoom(chart);
                                }
                            }
                        }
                    },
                    scales: {
                        x: {
                            ticks: { color: '#666', maxTicksLimit: 12, maxRotation: 0, font: { size: 13 } },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        'y-vl': {
                            type: 'linear',
                            position: 'left',
                            max: 5000,
                            title: { display: true, text: 'Viscosidad (cP)', color: '#4fc3f7', font: { size: 14 } },
                            ticks: { color: '#4fc3f7', font: { size: 13 } },
                            grid: { color: 'rgba(255,255,255,0.05)' }
                        },
                        'y-temp': {
                            type: 'linear',
                            position: 'right',
                            title: { display: true, text: 'Temperatura (\u00b0C)', color: '#ff8a65', font: { size: 14 } },
                            ticks: { color: '#ff8a65', font: { size: 13 } },
                            grid: { drawOnChartArea: false }
                        }
                    }
                }
            });
        }

        // ── Partidas — carga y popup ───────────────────────────────────────
        async function loadPartidas() {
            try {
                const res = await fetch('/api/partidas');
                allPartidas = await res.json();
                updateDrawerSelects();
            } catch(e) {}
        }

        function updateDrawerSelects() {
            const evtSel = document.getElementById('f-evento-partida');
            const mstSel = document.getElementById('f-muestra-partida');
            const savedEvt = evtSel.value;
            const savedMst = mstSel.value;

            evtSel.innerHTML = '<option value="">— Sin partida —</option>';
            mstSel.innerHTML = '<option value="">— Sin partida —</option>';

            allPartidas.forEach(p => {
                const label = `#${p.numero_partida} — ${p.fecha}${p.articulo ? ' — ' + p.articulo : ''}`;
                [evtSel, mstSel].forEach(s => {
                    const o = document.createElement('option');
                    o.value = p.id;
                    o.textContent = label;
                    s.appendChild(o);
                });
            });

            if (savedEvt) evtSel.value = savedEvt;
            if (savedMst) mstSel.value = savedMst;

            // Pre-select current partida in drawer forms
            if (currentPartidaId) {
                evtSel.value = String(currentPartidaId);
                mstSel.value = String(currentPartidaId);
            }
        }

        function openPartidaPopup() {
            const tbody = document.getElementById('partida-table-body');
            tbody.innerHTML = '';

            // Fila "En Vivo" — fuera de la tabla
            const liveSection = document.getElementById('partida-live-section');
            liveSection.innerHTML = '';
            const liveDiv = document.createElement('div');
            liveDiv.className = 'popup-live-row' + (appMode === 'live' ? ' selected' : '');
            liveDiv.innerHTML = '&#9679; DATOS EN TIEMPO REAL';
            liveDiv.addEventListener('click', () => {
                closePartidaPopup();
                setMode('live', null);
            });
            liveSection.appendChild(liveDiv);

            // Filas de partidas
            allPartidas.forEach(p => {
                const tr = document.createElement('tr');
                tr.className = 'partida-row' + (currentPartidaId === p.id && appMode === 'partida' ? ' selected' : '');
                tr.innerHTML = `
                    <td>${p.fecha}</td>
                    <td>#${p.numero_partida}</td>
                    <td>${p.articulo || '<span style="color:var(--text-dim)">—</span>'}</td>
                `;
                tr.addEventListener('click', () => {
                    closePartidaPopup();
                    setMode('partida', p.id);
                });
                tbody.appendChild(tr);
            });

            document.getElementById('partida-popup-overlay').classList.add('open');
        }

        function closePartidaPopup() {
            document.getElementById('partida-popup-overlay').classList.remove('open');
        }

        async function loadCurrentPartida() {
            try {
                const res = await fetch('/api/partidas/current');
                const p = await res.json();
                updatePartidaCard(p, 'live');
                if (p) {
                    currentPartidaId = p.id;
                    loadAnnotations(p.id);
                    // Pre-select in drawer forms
                    document.getElementById('f-evento-partida').value = String(p.id);
                    document.getElementById('f-muestra-partida').value = String(p.id);
                }
            } catch(e) {}
        }

        function updatePartidaCard(p, mode) {
            const pill = document.getElementById('partida-mode-pill');
            if (mode === 'live') {
                pill.textContent = '● En Vivo';
                pill.className = 'partida-mode-pill live';
