                    <div class="form-row">
                        <label>Partida</label>
                        <select id="f-muestra-partida"></select>
                    </div>
                    <div class="form-row-2">
                        <div class="form-row">
                            <label>Hora</label>
                            <input type="time" id="f-muestra-hora">
                        </div>
                        <div class="form-row">
                            <label>Tipo</label>
                            <select id="f-muestra-tipo">
                                <option value="lectura">Lectura</option>
                                <option value="laboratorio">Laboratorio</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-row">
                        <label>Instrumento</label>
                        <select id="f-muestra-instrumento">
                            <option value="">— ninguno —</option>
                            <option value="pipeta">Pipeta</option>
                            <option value="pico 5">Pico 5</option>
                            <option value="pico 7">Pico 7</option>
                        </select>
                    </div>
                    <div class="form-row-2">
                        <div class="form-row">
                            <label>Viscosidad</label>
                            <input type="number" id="f-muestra-visc" step="0.01" placeholder="0.00">
                        </div>
                        <div class="form-row">
                            <label>Temperatura °C</label>
