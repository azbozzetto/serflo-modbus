        // ── Annotations ────────────────────────────────────────────────────
        async function loadAnnotations(partidaId) {
            if (!partidaId || !chart) return;
            try {
                const [evtRes, mstRes] = await Promise.all([
                    fetch(`/api/partidas/${partidaId}/eventos`),
                    fetch(`/api/partidas/${partidaId}/muestras`)
                ]);
                const eventos  = await evtRes.json();
                const muestras = await mstRes.json();
                const labels   = chart.data.labels;
                const anns     = {};

                // ── Eventos: línea vertical, etiqueta en la parte superior ─────────
                // Constantes para font-size 14px bold
                const CHAR_W  = 8.0;   // ancho promedio por carácter a 14px bold
                const PAD_X   = 16;    // padding horizontal total + bordes
                const PAD_Y   = 10;    // padding vertical total
                const LINE_H  = 18;    // altura de línea a 14px
                const LBL_GAP = 6;     // separación vertical entre niveles

                // Ordenar por posición x para asignar niveles de izquierda a derecha
                const sortedEvts = [...eventos]
                    .filter(e => isTimeInRange(labels, e.hora_evento))
                    .sort((a, b) =>
                        findLabelIndex(labels, a.hora_evento) - findLabelIndex(labels, b.hora_evento)
                    );

                const levelRight = [];  // x pixel más a la derecha ocupado por nivel

                sortedEvts.forEach(e => {
                    const idx  = findLabelIndex(labels, e.hora_evento);
                    const desc = e.evento.length > 35 ? e.evento.substring(0, 32) + '\u2026' : e.evento;
                    const contentLines = e.temperatura_c != null
                        ? [desc, `${e.temperatura_c}\u00b0C`]
                        : [desc];

                    // Dimensiones estimadas del label
                    const maxChars = Math.max(...contentLines.map(l => l.length));
                    const labelW   = Math.round(maxChars * CHAR_W + PAD_X);
                    const labelH   = contentLines.length * LINE_H + PAD_Y;

                    // Píxel x de la línea
                    const xPx = chart.scales.x ? chart.scales.x.getPixelForValue(idx) : 0;

                    // xAdjust: borde izquierdo del label alineado con la línea vertical
                    const xAdjust = Math.round(labelW / 2 + 2);

                    // yAdjust: position:'start' ancla el borde SUPERIOR del label en
                    // chartArea.top → yAdjust=0 ya es el tope del gráfico, totalmente visible.
                    // Niveles sucesivos se desplazan hacia abajo por labelH + gap.
                    let level = 0;
                    while (levelRight[level] !== undefined && xPx < levelRight[level] + 6) {
                        level++;
                    }
                    levelRight[level] = xPx + labelW;
                    const yAdjust = level * (labelH + LBL_GAP);

                    anns[`evt_${e.id}`] = {
                        type: 'line',
                        xMin: idx,
                        xMax: idx,
                        drawTime: 'afterDraw',
                        borderColor: '#ffd54f',
                        borderWidth: 2,
                        borderDash: [6, 4],
                        label: {
                            display: true,
                            content: contentLines,
                            position: 'end',
                            rotation: 0,
                            xAdjust: xAdjust,
                            yAdjust: yAdjust,
                            backgroundColor: 'rgba(40,30,0,0.85)',
                            color: '#ffd54f',
                            borderColor: '#ffd54f',
                            borderWidth: 1,
                            borderRadius: { topLeft: 0, bottomLeft: 0, topRight: 4, bottomRight: 4 },
                            font: { size: 14, weight: '600' },
                            padding: { x: 6, y: 4 }
                        }
                    };
                });

                // ── Muestras: etiquetas verticales ancladas al fondo del chart ───
                const ylvMin      = chart.scales['y-vl'] ? chart.scales['y-vl'].min : 0;
                const MST_CALLOUT = 14;
                const MST_CHAR_W  = 8.0;
                const MST_PAD_X   = 16;

                muestras
                    .filter(m => isTimeInRange(labels, m.hora_medicion))
                    .forEach(m => {
                        const idx      = findLabelIndex(labels, m.hora_medicion);
                        const instrLbl = m.instrumento ? ' ' + m.instrumento.toUpperCase() : '';
                        const viscStr  = m.medicion_viscosidad.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                        const tempStr  = m.medicion_temperatura.toLocaleString('en-US', { minimumFractionDigits: 1, maximumFractionDigits: 1 });
                        const content  = [
                            `VISCO.${instrLbl} ${viscStr}`,
                            `TEMP. ${tempStr} \u00b0C`
                        ];
                        // Con rotation:-90 la anchura original del label pasa a ser la
                        // altura en pantalla. yAdjust sube el centro hasta que el borde
                        // inferior quede MST_CALLOUT px por encima del anchor (ylvMin).
                        const maxMstChars = Math.max(...content.map(l => l.length));
                        const mstLabelW   = Math.round(maxMstChars * MST_CHAR_W + MST_PAD_X);
                        const mstYAdj     = -(MST_CALLOUT + Math.round(mstLabelW / 2));

                        anns[`mst_${m.id}`] = {
                            type: 'label',
                            drawTime: 'afterDraw',
                            xValue: idx,
                            yScaleID: 'y-vl',
                            yValue: ylvMin,
                            yAdjust: mstYAdj,
                            rotation: -90,
                            content: content,
                            backgroundColor: 'rgba(15,35,18,0.92)',
                            color: '#a5d6a7',
                            borderWidth: 0,
                            borderRadius: 4,
                            font: { size: 14, weight: '500' },
                            textAlign: 'left',
                            padding: { x: 5, y: 3 },
                            callout: {
                                display: true,
                                position: 'auto',
                                side: 8,
                                borderColor: '#66bb6a',
                                borderWidth: 1
                            }
                        };
                    });

                console.log(`[annotations] partida ${partidaId}: ${eventos.length} eventos, ${muestras.length} muestras, ${labels.length} labels`);
                lastAnnotations = anns;
                applyAnnotationVisibility();
            } catch(e) {
                console.error('[annotations] error:', e);
            }
        }

        function clearAnnotations() {
            lastAnnotations = {};
            if (chart) {
                chart.options.plugins.annotation.annotations = {};
                chart.update('none');
            }
        }

        // ── Modo producción (partida histórica) ────────────────────────────
        function setMode(mode, partidaId) {
            appMode = mode;
            const timeCtrl = document.getElementById('time-controls');

            if (mode === 'partida' && partidaId) {
                currentPartidaId = partidaId;
                // Ocultar controles de tiempo/nav pero mantener visible el grupo derecho (zoom + expand)
                Array.from(timeCtrl.children).forEach(el => {
                    if (!el.classList.contains('ctrl-right-group')) el.style.display = 'none';
                });
                clearInterval(refreshTimer);
                const p = allPartidas.find(x => x.id === partidaId);
                updatePartidaCard(p || null, 'partida');
                document.getElementById('f-evento-partida').value = String(partidaId);
                document.getElementById('f-muestra-partida').value = String(partidaId);
                clearMeasurements();
                loadDataPartida(partidaId);
            } else {
                appMode = 'live';
                currentPartidaId = null;
                // Restaurar todos los controles de tiempo/nav
                Array.from(timeCtrl.children).forEach(el => { el.style.display = ''; });
                loadCurrentPartida();
                loadData();
                refreshTimer = setInterval(() => { if (!isZoomed) loadData(); }, REFRESH_INTERVAL);
            }
        }

        // ── Navegación (compartida teclado / botones / rueda) ──────────────
        function navigateBack() {
            if (appMode === 'partida') return;
            if (isZoomed) resetZoom();
            if (currentDayMode) {
                currentViewDate = addDays(currentViewDate, -1);
            } else {
                currentOffset += currentHours;
            }
            updateNavButtons();
            loadData();
        }

        function navigateFwd() {
            if (appMode === 'partida') return;
            if (isZoomed) resetZoom();
            if (currentDayMode) {
                if (currentViewDate >= todayStr()) return;
                currentViewDate = addDays(currentViewDate, 1);
            } else {
                currentOffset = Math.max(0, currentOffset - currentHours);
            }
            updateNavButtons();
            loadData();
        }

        // ── Carga de datos (producción) ────────────────────────────────────
        async function loadDataPartida(partidaId) {
            try {
                const dataRes = await fetch(`/api/readings?partida_id=${partidaId}`);
                const data = await dataRes.json();
                lastData = data;
                renderChart(data, 'day');
                populateRecentReadings(data);
                renderReadingsLog();
                loadAnnotations(partidaId);
            } catch(e) {
                renderReadingsLog();
                document.getElementById('status').textContent = '✕ Error';
                document.getElementById('status').className = 'status offline';
            }
        }

        // ── Carga de datos (live / day / histórico) ────────────────────────
        async function loadData() {
            try {
                let readingsUrl;
                if (currentDayMode) {
                    readingsUrl = `/api/readings?date=${currentViewDate}`;
                } else {
                    readingsUrl = `/api/readings?hours=${currentHours}&offset=${currentOffset}`;
                }

                const res = await fetch(readingsUrl);
                const data = await res.json();
                lastData = data;

                const labelMode = (currentDayMode || currentHours > 1) ? 'hhmm' : 'hhmmss';
                renderChart(data, labelMode);

                // Stats acumuladas + log del card — client-side desde los datos cargados
                populateRecentReadings(data);
                renderReadingsLog();

                // Actualizar card Partida según la fecha que se está visualizando
                if (appMode === 'live') {
                    const viewPid  = getViewPartidaId(data);
                    const viewP    = viewPid ? allPartidas.find(x => x.id === viewPid) : null;
                    const midTs    = data.timestamps && data.timestamps.length
                                     ? data.timestamps[Math.floor(data.timestamps.length / 2)].substring(0, 10)
                                     : todayStr();
                    updatePartidaCard(viewP, midTs === todayStr() ? 'live' : 'historical');
                }

                if (!currentDayMode && currentOffset === 0) {
                    // En live: puede aparecer una lectura más nueva que el dataset
                    const latestRes = await fetch('/api/latest');
                    if (latestRes.ok) {
                        const latest = await latestRes.json();
                        setMeasurements(latest.vl, latest.temperature, latest.temperature, latest.timestamp);
                        document.getElementById('status').textContent = '● Conectado';
                        document.getElementById('status').className = 'status online';
                    }
                }

                const annPid = getViewPartidaId(data);
                if (annPid) loadAnnotations(annPid);
                else clearAnnotations();

            } catch(err) {
                document.getElementById('status').textContent = '● Sin conexion';
                document.getElementById('status').className = 'status offline';
            }
        }

        function populateRecentReadings(data) {
            const n = data.timestamps ? data.timestamps.length : 0;
            recentReadings = [];
            if (n === 0) return;
            const rolling = computeRollingStats(data);
            for (let i = n - 1; i >= Math.max(0, n - MAX_LOG); i--) {
                recentReadings.push({
                    hora:  data.timestamps[i].substring(11, 19),
                    vl:    data.vl          ? data.vl[i]          : null,
                    temp:  data.temperature ? data.temperature[i] : null,
                    stats: rolling[i]        // stats acumuladas hasta este punto
                });
            }
        }

        function renderReadingsLog() {
            const tbody = document.getElementById('medicion-log-body');
            if (!tbody) return;
            let html = '';
            for (let i = 0; i < MAX_LOG; i++) {
                const r       = recentReadings[i] || null;
                const hora    = r ? r.hora : '—';
                const vlStr   = r && r.vl   != null ? fmtNum(r.vl,   0) : '—';
                const tempStr = r && r.temp != null ? fmtNum(r.temp, 0) : '—';
                // Stats acumuladas hasta el momento de esta lectura
                const s = r ? r.stats : null;
                const vlMin = s && s.vl   ? fmtNum(s.vl.min,   0) : '—';
                const vlMax = s && s.vl   ? fmtNum(s.vl.max,   0) : '—';
                const vlAvg = s && s.vl   ? fmtNum(s.vl.avg,   0) : '—';
                const tMin  = s && s.temp ? fmtNum(s.temp.min, 0) : '—';
                const tMax  = s && s.temp ? fmtNum(s.temp.max, 0) : '—';
                const tAvg  = s && s.temp ? fmtNum(s.temp.avg, 0) : '—';
                const cls   = i === 0 ? 'mlog-latest' : (!r ? 'mlog-placeholder' : '');
                html += `<tr class="mlog-row${cls ? ' ' + cls : ''}">
                    <td class="mlog-hora">${hora}</td>
                    <td class="mlog-real mlog-vl">${vlStr}</td>
                    <td class="mlog-stat">${vlMin}</td>
                    <td class="mlog-stat">${vlMax}</td>
                    <td class="mlog-stat">${vlAvg}</td>
                    <td class="mlog-real mlog-temp">${tempStr}</td>
                    <td class="mlog-stat">${tMin}</td>
                    <td class="mlog-stat">${tMax}</td>
                    <td class="mlog-stat">${tAvg}</td>
                </tr>`;
            }
            tbody.innerHTML = html;
            // Total de lecturas al pie del card
            const tot = document.getElementById('stat-total');
            const n = lastData && lastData.timestamps ? lastData.timestamps.length : 0;
            if (tot) tot.textContent = n ? n.toLocaleString('en-US') + ' lecturas' : '';
        }

        function setMeasurements(vl, temp, _ignored, timestamp) {
            const hora = timestamp ? timestamp.substring(11, 19) : '—';
            if (recentReadings.length > 0 && recentReadings[0].hora === hora) return;
            // Extender stats acumuladas desde la entrada anterior
            const prevStats = recentReadings.length > 0 ? recentReadings[0].stats : null;
            const newStats  = extendStats(prevStats, vl, temp);
            recentReadings.unshift({ hora, vl, temp, stats: newStats });
            if (recentReadings.length > MAX_LOG) recentReadings.pop();
            renderReadingsLog();
        }

        function clearMeasurements() {
            // En modo histórico/partida: conserva las lecturas del dataset pero limpia
            // el primer slot para que apunte a los datos del período, no live.
            // Si el caller ya llamó populateRecentReadings antes, solo re-renderizamos.
            renderReadingsLog();
        }

        function renderChart(data, labelMode) {
            const labels = data.timestamps.map(ts => {
                if (labelMode === 'hhmmss') return ts.substring(11, 19);
                if (labelMode === 'hhmm')   return ts.substring(11, 16);
                return ts.substring(5, 16);
            });
            chart.data.labels = labels;
            chart.data.datasets[0].data = data.vl;
            chart.data.datasets[1].data = data.temperature;
            chart.update('none');
        }


        // ── Escala ─────────────────────────────────────────────────────────
        function applyScales() {
            const vlAuto = document.getElementById('vl-auto').checked;
            const tempAuto = document.getElementById('temp-auto').checked;
            const vlScale = chart.options.scales['y-vl'];
            const tempScale = chart.options.scales['y-temp'];

            if (vlAuto) {
                delete vlScale.min; delete vlScale.max;
            } else {
                const min = parseFloat(document.getElementById('vl-min').value);
                const max = parseFloat(document.getElementById('vl-max').value);
                if (!isNaN(min)) vlScale.min = min; else delete vlScale.min;
                if (!isNaN(max)) vlScale.max = max; else delete vlScale.max;
            }
            if (tempAuto) {
                delete tempScale.min; delete tempScale.max;
            } else {
                const min = parseFloat(document.getElementById('temp-min').value);
                const max = parseFloat(document.getElementById('temp-max').value);
                if (!isNaN(min)) tempScale.min = min; else delete tempScale.min;
                if (!isNaN(max)) tempScale.max = max; else delete tempScale.max;
            }
            chart.update();
            renderReadingsLog();  // re-pinta el card (stats por fila, no cambian con la escala)
        }

        function updateMedicionesForZoom(chart) {
            if (!lastData || !lastData.timestamps || !lastData.timestamps.length) return;
            const xScale = chart.scales.x;
            const total  = lastData.timestamps.length;
            const minIdx = Math.max(0,         Math.floor(xScale.min));
            const maxIdx = Math.min(total - 1, Math.ceil(xScale.max));
            if (minIdx > maxIdx) return;
            const sliced = {
                timestamps:  lastData.timestamps.slice(minIdx, maxIdx + 1),
                vl:          lastData.vl          ? lastData.vl.slice(minIdx, maxIdx + 1)          : [],
                temperature: lastData.temperature ? lastData.temperature.slice(minIdx, maxIdx + 1) : []
            };
            populateRecentReadings(sliced);
            renderReadingsLog();
        }

        function resetZoom() {
            chart.resetZoom();
            isZoomed = false;
            document.getElementById('btn-reset-zoom').classList.remove('zoomed');
            updateRefreshInfo();
            // Restaurar MEDICIONES al dataset completo
            if (lastData) { populateRecentReadings(lastData); renderReadingsLog(); }
        }

        function updateRefreshInfo() {
            let txt;
            if (appMode === 'partida') {
                txt = 'Vista de partida';
            } else if (currentDayMode) {
                const today = todayStr();
                txt = currentViewDate === today
                    ? `Hoy — ${currentViewDate}`
                    : `D\u00eda: ${currentViewDate}`;
            } else if (currentOffset > 0) {
                txt = `Vista hist\u00f3rica \u2014 hace ${currentOffset}h`;
            } else {
                txt = `Actualiza cada ${REFRESH_INTERVAL / 1000}s`;
            }
            document.getElementById('refresh-info').textContent = txt;
        }

        function updateNavButtons() {
            const fwd  = document.getElementById('btn-fwd');
            const auto = document.getElementById('btn-auto');

            if (currentDayMode) {
                fwd.disabled = currentViewDate >= todayStr();
                if (auto) auto.classList.toggle('is-live', currentViewDate >= todayStr());
            } else {
                fwd.disabled = currentOffset === 0;
                if (auto) auto.classList.toggle('is-live', currentOffset === 0);
            }
            updateRefreshInfo();
        }

        function setDayMode(active) {
            currentDayMode = active;
            document.getElementById('btn-day-mode').classList.toggle('active', active);
            // Desactivar botones de horas cuando está en modo día
            document.querySelectorAll('.controls button[data-hours]').forEach(b => {
                if (active) b.classList.remove('active');
            });
        }

        function downloadCSV() {
            if (!lastData || lastData.count === 0) return;
            let csv = 'Timestamp,VL_cP,Temperature_C\n';
            for (let i = 0; i < lastData.timestamps.length; i++) {
                csv += `${lastData.timestamps[i] || ''},${lastData.vl[i] ?? ''},${lastData.temperature[i] ?? ''}\n`;
            }
            const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            const suffix = appMode === 'partida' ? `partida${currentPartidaId}` : `${currentHours}h_off${currentOffset}h`;
            a.download = `hp550_${suffix}_${new Date().toISOString().slice(0,10)}.csv`;
            a.click();
            URL.revokeObjectURL(url);
        }

