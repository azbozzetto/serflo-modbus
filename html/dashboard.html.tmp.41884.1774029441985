                    <div class="form-row">
                        <label>Partida</label>
                        <select id="f-evento-partida"></select>
                    </div>
                    <div class="form-row-2">
                        <div class="form-row">
                            <label>Hora</label>
                            <input type="time" id="f-evento-hora">
