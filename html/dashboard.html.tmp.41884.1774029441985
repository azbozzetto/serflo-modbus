        // ── Formulario: Partida ────────────────────────────────────────────
        document.getElementById('f-partida-fecha').value = todayStr();
        document.getElementById('form-partida').addEventListener('submit', async function(e) {
            e.preventDefault();
            const msg = document.getElementById('msg-partida');
            const fecha = document.getElementById('f-partida-fecha').value;
            const num = document.getElementById('f-partida-num').value;
            const art = document.getElementById('f-partida-articulo').value;
            if (!fecha || !num) { msg.textContent = 'Fecha y N° son requeridos'; msg.className = 'form-msg err'; return; }
            try {
                const res = await fetch('/api/partidas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ fecha, numero_partida: parseInt(num), articulo: art || null })
                });
                if (res.ok) {
                    const p = await res.json();
                    msg.textContent = `Partida #${p.numero_partida} creada`;
                    msg.className = 'form-msg ok';
                    document.getElementById('f-partida-num').value = '';
                    document.getElementById('f-partida-articulo').value = '';
                    await loadPartidas();
                    setMode('partida', p.id);
                } else {
                    const err = await res.json();
                    msg.textContent = err.error || 'Error al crear partida';
                    msg.className = 'form-msg err';
                }
            } catch(ex) { msg.textContent = 'Error de conexión'; msg.className = 'form-msg err'; }
        });

        // ── Formulario: Evento ─────────────────────────────────────────────
        document.getElementById('f-evento-hora').value = nowTimeStr();
        document.getElementById('form-evento').addEventListener('submit', async function(e) {
            e.preventDefault();
            const msg = document.getElementById('msg-evento');
            const pid = document.getElementById('f-evento-partida').value;
            const hora = document.getElementById('f-evento-hora').value;
            const temp = document.getElementById('f-evento-temp').value;
            const texto = document.getElementById('f-evento-texto').value.trim();
            if (!pid) { msg.textContent = 'Seleccione una partida'; msg.className = 'form-msg err'; return; }
            if (!hora || !texto) { msg.textContent = 'Hora y evento son requeridos'; msg.className = 'form-msg err'; return; }
            try {
                const res = await fetch(`/api/partidas/${pid}/eventos`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ hora_evento: hora, temperatura_c: temp ? parseFloat(temp) : null, evento: texto })
                });
                if (res.ok) {
                    msg.textContent = 'Evento registrado';
                    msg.className = 'form-msg ok';
                    document.getElementById('f-evento-texto').value = '';
                    document.getElementById('f-evento-hora').value = nowTimeStr();
                    if (getViewPartidaId(lastData) === parseInt(pid)) loadAnnotations(parseInt(pid));
                } else {
                    const err = await res.json();
                    msg.textContent = err.error || 'Error';
                    msg.className = 'form-msg err';
                }
            } catch(ex) { msg.textContent = 'Error de conexión'; msg.className = 'form-msg err'; }
        });

        // ── Formulario: Muestra ────────────────────────────────────────────
        document.getElementById('f-muestra-hora').value = nowTimeStr();
        document.getElementById('form-muestra').addEventListener('submit', async function(e) {
            e.preventDefault();
            const msg = document.getElementById('msg-muestra');
            const pid = document.getElementById('f-muestra-partida').value;
            const hora = document.getElementById('f-muestra-hora').value;
            const tipo = document.getElementById('f-muestra-tipo').value;
            const inst = document.getElementById('f-muestra-instrumento').value || null;
            const visc = document.getElementById('f-muestra-visc').value;
            const temp = document.getElementById('f-muestra-temp').value;
            if (!pid) { msg.textContent = 'Seleccione una partida'; msg.className = 'form-msg err'; return; }
            if (!hora || !visc || !temp) { msg.textContent = 'Hora, viscosidad y temperatura son requeridos'; msg.className = 'form-msg err'; return; }
            try {
                const res = await fetch(`/api/partidas/${pid}/muestras`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        hora_medicion: hora,
                        tipo_medicion: tipo,
                        instrumento: inst,
                        medicion_viscosidad: parseFloat(visc),
                        medicion_temperatura: parseFloat(temp)
                    })
                });
                if (res.ok) {
                    msg.textContent = 'Muestra registrada';
                    msg.className = 'form-msg ok';
                    document.getElementById('f-muestra-visc').value = '';
                    document.getElementById('f-muestra-temp').value = '';
                    document.getElementById('f-muestra-hora').value = nowTimeStr();
                    if (getViewPartidaId(lastData) === parseInt(pid)) loadAnnotations(parseInt(pid));
                } else {
                    const err = await res.json();
                    msg.textContent = err.error || 'Error';
                    msg.className = 'form-msg err';
                }
            } catch(ex) { msg.textContent = 'Error de conexión'; msg.className = 'form-msg err'; }
        });

        // ── Inicialización ─────────────────────────────────────────────────
        // VL: auto desactivado por defecto, max=5000
        document.getElementById('vl-auto').checked = false;
        document.getElementById('vl-min').disabled = false;
        document.getElementById('vl-max').disabled = false;

        // Arrancar en modo día (hoy) por defecto
        setDayMode(true);
        currentViewDate = todayStr();

        updateRefreshInfo();
        initChart();
        loadPartidas().then(() => loadCurrentPartida());
        loadData();
        refreshTimer = setInterval(() => {
            if (!isZoomed && appMode === 'live') loadData();
        }, REFRESH_INTERVAL);
    </script>
</body>
</html>
